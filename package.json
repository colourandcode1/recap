{
  "name": "recap-ux",
  "version": "0.1.0",
  "description": "Lightweight, privacy-first usability tracking for web prototypes. Zero cookies, zero PII, client-side heatmaps.",
  "type": "module",
  "author": "",
  "license": "MIT",
  "keywords": [
    "usability",
    "heatmap",
    "ux",
    "analytics",
    "privacy"
  ],
  "main": "./dist/recap.cjs.js",
  "module": "./dist/recap.esm.js",
  "browser": "./dist/recap.min.js",
  "exports": {
    ".": {
      "import": "./dist/recap.esm.js",
      "require": "./dist/recap.cjs.js"
    },
    "./react": {
      "import": "./dist/recap-react.esm.js",
      "require": "./dist/recap-react.cjs.js"
    }
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.2",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
